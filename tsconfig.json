{
  "compilerOptions": {
    //"target": "es2020",
    //"module": "esnext",
    
    "target": "ESNext",
    "module": "nodenext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["node","@playwright/test"],
    "skipLibCheck": true,
    "noEmit": false,
    "rootDir": ".",
    "outDir": "dist"
  },
  "ts-node": {
    "transpileOnly": true,
    "experimentalSpecifierResolution": "node"
  },
  "include": [
    "src/**/*.ts"
  ]
}
